# ---------------------------------------------------------------------------
# memory-service — exemple de configuration.
# Copier en `.env` puis ajuster. NE JAMAIS committer le `.env` réel.
# ---------------------------------------------------------------------------

# --- API ---
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# --- PostgreSQL (graphe + pgvector) ---
POSTGRES_USER=memory
POSTGRES_PASSWORD=change-me
POSTGRES_DB=memory
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# URL de connexion dérivée, utilisée par l'app et le worker.
DATABASE_URL=postgresql+asyncpg://memory:change-me@postgres:5432/memory

# --- Redis (buffer short-term + broker worker) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- Embeddings / vector store ---
# Dimension des vecteurs pgvector. Doit correspondre au modèle d'embedding choisi.
EMBEDDING_DIM=1536
# Fournisseur d'embedding (local/onnx recommandé pour rester provider-agnostic).
EMBEDDING_BACKEND=local

# Backends pluggables d'ingestion (défauts déterministes, sans API payante).
EXTRACTION_BACKEND=heuristic
COREF_BACKEND=rules

# --- Context builder ---
# Budget de tokens strict pour la linéarisation du contexte injecté.
CONTEXT_TOKEN_BUDGET=2000

# --- Consolidation (worker) ---
# Expression cron du job nocturne de consolidation (merge + decay).
CONSOLIDATION_CRON=0 3 * * *
# Stratégie de résolution de contradiction : "lww" | "llm_arbitration"
CONTRADICTION_STRATEGY=lww

# --- Multi-tenant ---
# Mode d'isolation : "header" (X-Tenant-Id) | "jwt" | "oidc" | "single" (dev only)
TENANT_MODE=header

# --- Web app (/app) : visualiseur de mémoire ---
# Répertoire des fichiers statiques du SPA (index.html + assets). En docker-compose
# il est bind-monté depuis ../memory-ui/app vers /webapp. En local (uvicorn lancé
# depuis memory-service/), le défaut ../memory-ui/app fonctionne tel quel.
WEBAPP_DIR=../memory-ui/app
# Client OAuth PUBLIC (navigateur) pour le login PKCE vers Mindlog.id. Vide → le
# SPA propose seulement le collage d'un Bearer (dev). À renseigner pour un vrai login.
OIDC_CLIENT_ID=
# Endpoints OAuth (optionnels : sinon découverte via {OIDC_ISSUER}/.well-known/openid-configuration)
OIDC_AUTHORIZATION_ENDPOINT=
OIDC_TOKEN_ENDPOINT=
OIDC_SCOPES=openid profile

# --- CORS ---
# Origines autorisées pour les connecteurs MCP côté navigateur (Grok, ChatGPT…).
# Liste séparée par des virgules ; "*" = tout autoriser (auth par Bearer, pas cookie).
# Sans CORS, ces connecteurs affichent "Connection failed" (Claude n'est pas concerné).
CORS_ALLOW_ORIGINS=*

# --- Auth JWT (utilisé si TENANT_MODE=jwt) ---
# Secret HS256 de vérification des jetons. OBLIGATOIRE en mode jwt.
JWT_SECRET=change-me-too
JWT_ALGORITHM=HS256
# Nom des claims portant l'identité dans le JWT.
JWT_TENANT_CLAIM=tenant_id
JWT_USER_CLAIM=user_id
